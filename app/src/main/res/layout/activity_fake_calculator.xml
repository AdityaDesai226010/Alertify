<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212"
    android:padding="16dp">

    <!-- Calculator Display -->
    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom|end"
        android:padding="20dp"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="60sp" />

    <!-- Calculator Buttons Grid -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="4"
        android:rowCount="5">

        <!-- Row 1 -->
        <Button style="@style/CalcButton" android:text="C" android:textColor="#FF9800" android:onClick="onClearClick"/>
        <Button style="@style/CalcButton" android:text="+/-" android:onClick="onNumberClick"/>
        <Button style="@style/CalcButton" android:text="%" android:onClick="onNumberClick"/>
        <Button style="@style/CalcButton" android:text="/" android:backgroundTint="#FF9800" android:onClick="onNumberClick"/>

        <!-- Row 2 -->
        <Button style="@style/CalcButton" android:text="7" android:onClick="onNumberClick"/>
        <Button style="@style/CalcButton" android:text="8" android:onClick="onNumberClick"/>
        <Button style="@style/CalcButton" android:text="9" android:onClick="onNumberClick"/>
        <Button style="@style/CalcButton" android:text="*" android:backgroundTint="#FF9800" android:onClick="onNumberClick"/>

        <!-- Row 3 -->
        <Button style="@style/CalcButton" android:text="4" android:onClick="onNumberClick"/>
        <Button style="@style/CalcButton" android:text="5" android:onClick="onNumberClick"/>
        <Button style="@style/CalcButton" android:text="6" android:onClick="onNumberClick"/>
        <Button style="@style/CalcButton" android:text="-" android:backgroundTint="#FF9800" android:onClick="onNumberClick"/>

        <!-- Row 4 -->
        <Button style="@style/CalcButton" android:text="1" android:onClick="onNumberClick"/>
        <Button style="@style/CalcButton" android:text="2" android:onClick="onNumberClick"/>
        <Button style="@style/CalcButton" android:text="3" android:onClick="onNumberClick"/>
        <Button style="@style/CalcButton" android:text="+" android:backgroundTint="#FF9800" android:onClick="onNumberClick"/>

        <!-- Row 5 -->
        <Button style="@style/CalcButton" android:text="0" android:layout_columnSpan="2" android:layout_width="0dp" android:layout_gravity="fill_horizontal" android:onClick="onNumberClick"/>
        <Button style="@style/CalcButton" android:text="." android:onClick="onNumberClick"/>
        <Button style="@style/CalcButton" android:text="=" android:backgroundTint="#FF9800" android:onClick="onNumberClick"/>

    </GridLayout>

</LinearLayout>
